{
  "name": "dmd_test",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/postgres": "^2.1.2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4.13.0",
    "dotenv": "^17.4.2",
    "express": "^4",
    "pg": "^8.17.2"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "dummy"
      },
      "db": {
        "kind": "postgres",
        "credentials": {
          "host": "${DB_HOST}",
          "port": "${DB_PORT}",
          "database": "${DB_NAME}",
          "user": "${DB_USER}",
          "password": "${DB_PASSWORD}"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/project1"
  ]
}
