<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
        <ComboBox
        width="100%"
        selectedKey="{
            path: 'filterValues>/status',
            type: 'sap.fe.macros.filter.type.Value',
            formatOptions: {
                operator: 'EQ'
            }
        }"
    >
            <items>
            <core:Item key="YET_TO_START" text="Yet to Start" />
            <core:Item key="IN_PROGRESS"  text="In Progress" />
            <core:Item key="COMPLETED"    text="Completed" />
            <core:Item key="ON_HOLD"      text="On Hold" />
        </items>
        </ComboBox>
</core:FragmentDefinition>